{
  "expo": {
    "name": "Plantão USG",
    "slug": "plantao-usg",
    "version": "1.0.0",
    "scheme": "plantao-usg",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "web": { "bundler": "metro" },
    "ios": {
      "bundleIdentifier": "com.laudousg.plantaousg",
      "supportsTablet": false
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-speech-recognition",
        { "microphonePermission": "Plantão USG usa o microfone para transcrição de voz nos laudos." }
      ]
    ],
    "experiments": { "typedRoutes": true }
  }
}
